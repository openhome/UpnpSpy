<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="UpnpSpy.App.Views.DevicePropertiesWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:UpnpSpy.Core.ViewModels"
    xmlns:desc="using:UpnpSpy.Core.Description"
    xmlns:local="using:UpnpSpy.App.Views">
    <UserControl x:Name="Root">
        <UserControl.Resources>
            <DataTemplate x:Key="PropertyTextRowTemplate" x:DataType="vm:PropertyTextRow">
                <Grid ColumnSpacing="12" Margin="0,2,0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="{x:Bind Label}"
                               Style="{StaticResource PropertyLabelTextBlockStyle}" />
                    <TextBlock Grid.Column="1"
                               Text="{x:Bind Value}"
                               Style="{StaticResource PropertyValueTextBlockStyle}" />
                </Grid>
            </DataTemplate>

            <DataTemplate x:Key="PropertyLinkRowTemplate" x:DataType="vm:PropertyLinkRow">
                <Grid ColumnSpacing="12" Margin="0,2,0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="{x:Bind Label}"
                               Style="{StaticResource PropertyLabelTextBlockStyle}" />
                    <HyperlinkButton Grid.Column="1"
                                     Content="{x:Bind Value}"
                                     NavigateUri="{x:Bind LinkUri}"
                                     Padding="0" />
                </Grid>
            </DataTemplate>

            <local:PropertyRowTemplateSelector x:Key="PropertyRowSelector"
                TextTemplate="{StaticResource PropertyTextRowTemplate}"
                LinkTemplate="{StaticResource PropertyLinkRowTemplate}" />
        </UserControl.Resources>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="20,20,20,8" Spacing="2">
                <TextBlock Text="{Binding Title, Mode=OneWay}"
                           Style="{ThemeResource SubtitleTextBlockStyle}" />
                <TextBlock Text="Read-only view of the device's UPnP description and SSDP metadata"
                           Style="{ThemeResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <InfoBar Grid.Row="1"
                     Margin="20,0,20,0"
                     IsOpen="{Binding IsDeviceUnreachable, Mode=OneWay}"
                     IsClosable="False"
                     Severity="Warning"
                     Title="Device no longer reachable"
                     Message="The device has gone away. Properties shown reflect its last-known state." />

            <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8"
                        Margin="20,12,20,0">
                <Button Click="OnCopyAllClicked">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                  Glyph="&#xE8C8;" FontSize="14" />
                        <TextBlock Text="Copy all" />
                    </StackPanel>
                </Button>
            </StackPanel>

            <ScrollViewer Grid.Row="3">
                <StackPanel Padding="20,12,20,20" Spacing="6">

                    <ItemsControl ItemsSource="{Binding Sections}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:PropertySection">
                                <StackPanel Spacing="4" Margin="0,0,0,4">
                                    <TextBlock Text="{x:Bind Title}"
                                               Style="{StaticResource SectionHeaderTextBlockStyle}" />
                                    <ItemsControl ItemsSource="{x:Bind Rows}"
                                                  ItemTemplateSelector="{StaticResource PropertyRowSelector}" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="Embedded devices"
                               Style="{StaticResource SectionHeaderTextBlockStyle}" />
                    <ItemsControl ItemsSource="{Binding EmbeddedDevices}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="desc:EmbeddedDeviceSummary">
                                <StackPanel Orientation="Vertical" Margin="0,2,0,2">
                                    <TextBlock IsTextSelectionEnabled="True">
                                        <Run Text="{x:Bind FriendlyName}" />
                                        <Run Text=" — " Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                        <Run Text="{x:Bind DeviceType}" FontFamily="Consolas" />
                                    </TextBlock>
                                    <TextBlock Text="{x:Bind Udn}"
                                               FontFamily="Consolas"
                                               FontSize="11"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                               IsTextSelectionEnabled="True" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </UserControl>
</Window>

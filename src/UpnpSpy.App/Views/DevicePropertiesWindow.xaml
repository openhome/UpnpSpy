<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="UpnpSpy.App.Views.DevicePropertiesWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:desc="using:UpnpSpy.Core.Description">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="TitleText"
                   Grid.Row="0"
                   Margin="16,16,16,4"
                   FontSize="18"
                   FontWeight="SemiBold" />

        <InfoBar x:Name="UnreachableBar"
                 Grid.Row="1"
                 Margin="16,0,16,8"
                 IsOpen="False"
                 IsClosable="False"
                 Severity="Warning"
                 Title="Device no longer reachable"
                 Message="The device has gone away. Properties shown reflect its last-known state." />

        <ScrollViewer Grid.Row="2">
            <StackPanel Padding="16,4,16,16" Spacing="14">

                <TextBlock Text="Identity" FontSize="14" FontWeight="SemiBold" />
                <Grid ColumnSpacing="12" RowSpacing="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Friendly name"
                               Foreground="{ThemeResource SystemControlDescriptionTextForegroundBrush}" />
                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="FriendlyNameText" IsTextSelectionEnabled="True" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Device type"
                               Foreground="{ThemeResource SystemControlDescriptionTextForegroundBrush}" />
                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="DeviceTypeText"
                               FontFamily="Consolas" IsTextSelectionEnabled="True" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="UUID"
                               Foreground="{ThemeResource SystemControlDescriptionTextForegroundBrush}" />
                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="UuidText"
                               FontFamily="Consolas" IsTextSelectionEnabled="True" />

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Presentation URL"
                               Foreground="{ThemeResource SystemControlDescriptionTextForegroundBrush}" />
                    <HyperlinkButton Grid.Row="3" Grid.Column="1" x:Name="PresentationUrlLink" Padding="0" />
                </Grid>

                <TextBlock Text="Manufacturer" FontSize="14" FontWeight="SemiBold" />
                <Grid ColumnSpacing="12" RowSpacing="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Manufacturer"
                               Foreground="{ThemeResource SystemControlDescriptionTextForegroundBrush}" />
                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="ManufacturerText" IsTextSelectionEnabled="True" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Manufacturer URL"
                               Foreground="{ThemeResource SystemControlDescriptionTextForegroundBrush}" />
                    <HyperlinkButton Grid.Row="1" Grid.Column="1" x:Name="ManufacturerUrlLink" Padding="0" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Model name"
                               Foreground="{ThemeResource SystemControlDescriptionTextForegroundBrush}" />
                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="ModelNameText" IsTextSelectionEnabled="True" />

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Model number"
                               Foreground="{ThemeResource SystemControlDescriptionTextForegroundBrush}" />
                    <TextBlock Grid.Row="3" Grid.Column="1" x:Name="ModelNumberText" IsTextSelectionEnabled="True" />

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Model description"
                               Foreground="{ThemeResource SystemControlDescriptionTextForegroundBrush}" />
                    <TextBlock Grid.Row="4" Grid.Column="1" x:Name="ModelDescriptionText"
                               TextWrapping="Wrap" IsTextSelectionEnabled="True" />

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Model URL"
                               Foreground="{ThemeResource SystemControlDescriptionTextForegroundBrush}" />
                    <HyperlinkButton Grid.Row="5" Grid.Column="1" x:Name="ModelUrlLink" Padding="0" />

                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Serial number"
                               Foreground="{ThemeResource SystemControlDescriptionTextForegroundBrush}" />
                    <TextBlock Grid.Row="6" Grid.Column="1" x:Name="SerialNumberText"
                               FontFamily="Consolas" IsTextSelectionEnabled="True" />

                    <TextBlock Grid.Row="7" Grid.Column="0" Text="UPC"
                               Foreground="{ThemeResource SystemControlDescriptionTextForegroundBrush}" />
                    <TextBlock Grid.Row="7" Grid.Column="1" x:Name="UpcText"
                               FontFamily="Consolas" IsTextSelectionEnabled="True" />
                </Grid>

                <TextBlock Text="Network" FontSize="14" FontWeight="SemiBold" />
                <Grid ColumnSpacing="12" RowSpacing="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Location URL"
                               Foreground="{ThemeResource SystemControlDescriptionTextForegroundBrush}" />
                    <HyperlinkButton Grid.Row="0" Grid.Column="1" x:Name="LocationUrlLink" Padding="0" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Endpoint"
                               Foreground="{ThemeResource SystemControlDescriptionTextForegroundBrush}" />
                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="EndpointText"
                               FontFamily="Consolas" IsTextSelectionEnabled="True" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="SERVER header"
                               Foreground="{ThemeResource SystemControlDescriptionTextForegroundBrush}" />
                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="ServerHeaderText"
                               FontFamily="Consolas" TextWrapping="Wrap" IsTextSelectionEnabled="True" />

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="CACHE-CONTROL max-age"
                               Foreground="{ThemeResource SystemControlDescriptionTextForegroundBrush}" />
                    <TextBlock Grid.Row="3" Grid.Column="1" x:Name="CacheControlText" IsTextSelectionEnabled="True" />
                </Grid>

                <TextBlock Text="Discovery history" FontSize="14" FontWeight="SemiBold" />
                <Grid ColumnSpacing="12" RowSpacing="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="First seen"
                               Foreground="{ThemeResource SystemControlDescriptionTextForegroundBrush}" />
                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="FirstSeenText"
                               FontFamily="Consolas" IsTextSelectionEnabled="True" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Last seen"
                               Foreground="{ThemeResource SystemControlDescriptionTextForegroundBrush}" />
                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="LastSeenText"
                               FontFamily="Consolas" IsTextSelectionEnabled="True" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Alive count"
                               Foreground="{ThemeResource SystemControlDescriptionTextForegroundBrush}" />
                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="AliveCountText" IsTextSelectionEnabled="True" />

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="BOOTID.UPNP.ORG"
                               Foreground="{ThemeResource SystemControlDescriptionTextForegroundBrush}" />
                    <TextBlock Grid.Row="3" Grid.Column="1" x:Name="BootIdText" IsTextSelectionEnabled="True" />

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="CONFIGID.UPNP.ORG"
                               Foreground="{ThemeResource SystemControlDescriptionTextForegroundBrush}" />
                    <TextBlock Grid.Row="4" Grid.Column="1" x:Name="ConfigIdText" IsTextSelectionEnabled="True" />
                </Grid>

                <TextBlock Text="Embedded devices" FontSize="14" FontWeight="SemiBold" />
                <TextBlock x:Name="NoEmbeddedText"
                           Text="(none declared)"
                           Foreground="{ThemeResource SystemControlDescriptionTextForegroundBrush}"
                           Visibility="Collapsed" />
                <ItemsControl x:Name="EmbeddedDevicesList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="desc:EmbeddedDeviceSummary">
                            <StackPanel Orientation="Vertical" Margin="0,2,0,2">
                                <TextBlock IsTextSelectionEnabled="True">
                                    <Run Text="{x:Bind FriendlyName}" />
                                    <Run Text=" — " Foreground="{ThemeResource SystemControlDescriptionTextForegroundBrush}" />
                                    <Run Text="{x:Bind DeviceType}" FontFamily="Consolas" />
                                </TextBlock>
                                <TextBlock Text="{x:Bind Udn}"
                                           FontFamily="Consolas"
                                           FontSize="11"
                                           Foreground="{ThemeResource SystemControlDescriptionTextForegroundBrush}"
                                           IsTextSelectionEnabled="True" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>

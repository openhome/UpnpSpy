<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="UpnpSpy.App.Views.SsdpLogView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:UpnpSpy.Core.Models">

    <UserControl.Resources>
        <DataTemplate x:Key="SsdpLogEntryTemplate" x:DataType="models:SsdpLogEntry">
            <Grid Padding="8,2" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="72" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{x:Bind ReceivedUtc.LocalDateTime, Mode=OneTime}"
                           FontFamily="Consolas"
                           IsTextSelectionEnabled="True" />
                <TextBlock Grid.Column="1"
                           Text="{x:Bind Kind, Mode=OneTime}"
                           FontFamily="Consolas"
                           IsTextSelectionEnabled="True" />
                <TextBlock Grid.Column="2"
                           Text="{x:Bind DeviceUuid, Mode=OneTime}"
                           FontFamily="Consolas"
                           TextTrimming="CharacterEllipsis"
                           IsTextSelectionEnabled="True" />
            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Padding="8,4" ColumnSpacing="12"
              Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180" />
                <ColumnDefinition Width="72" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Received (local)" FontWeight="SemiBold" />
            <TextBlock Grid.Column="1" Text="Kind" FontWeight="SemiBold" />
            <TextBlock Grid.Column="2" Text="Device UUID" FontWeight="SemiBold" />
        </Grid>

        <Grid Grid.Row="1">
            <ListView x:Name="EntriesList"
                      ItemsSource="{x:Bind ViewModel.Entries, Mode=OneWay}"
                      ItemTemplate="{StaticResource SsdpLogEntryTemplate}"
                      SelectionMode="None"
                      IsItemClickEnabled="False"
                      Loaded="OnListViewLoaded"
                      Unloaded="OnListViewUnloaded">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="MinHeight" Value="0" />
                    </Style>
                </ListView.ItemContainerStyle>
            </ListView>

            <!--
                Empty state: hidden once the first advertisement arrives. Placed
                inside the list grid so it overlays the empty ListView.
            -->
            <StackPanel Style="{StaticResource EmptyStatePanelStyle}"
                        IsHitTestVisible="False"
                        Visibility="{x:Bind ViewModel.Entries.Count, Mode=OneWay, Converter={StaticResource ZeroCountToVisibility}}">
                <FontIcon Glyph="&#xE7C3;" Style="{StaticResource EmptyStateGlyphStyle}" />
                <TextBlock Text="No SSDP traffic seen yet"
                           Style="{StaticResource EmptyStateTitleTextBlockStyle}" />
                <TextBlock Style="{StaticResource EmptyStateBodyTextBlockStyle}"
                           Text="Every ALIVE/BYEBYE advertisement received on the selected adapter will appear here. Quiet networks can take a few seconds before the first message arrives." />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>

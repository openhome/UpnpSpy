<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="UpnpSpy.App.Views.DiagnosticsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:UpnpSpy.Core.ViewModels"
    Title="Diagnostics">
    <Grid Padding="16" RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Text="Diagnostics" />

        <Grid Grid.Row="1" ColumnSpacing="8" Padding="0,4,0,4"
              Background="{ThemeResource SystemControlBackgroundBaseLowBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="80" />
                <ColumnDefinition Width="180" />
                <ColumnDefinition Width="180" />
                <ColumnDefinition Width="140" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Timestamp" FontWeight="SemiBold" />
            <TextBlock Grid.Column="1" Text="Severity" FontWeight="SemiBold" />
            <TextBlock Grid.Column="2" Text="Category" FontWeight="SemiBold" />
            <TextBlock Grid.Column="3" Text="Identity" FontWeight="SemiBold" />
            <TextBlock Grid.Column="4" Text="Endpoint" FontWeight="SemiBold" />
            <TextBlock Grid.Column="5" Text="Message" FontWeight="SemiBold" />
        </Grid>

        <ListView x:Name="EntriesList"
                  Grid.Row="2"
                  SelectionMode="Single"
                  IsItemClickEnabled="False">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:DiagnosticEntryRow">
                    <Grid ColumnSpacing="8" Padding="0,2,0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{x:Bind Timestamp}"
                                   FontFamily="Consolas" />
                        <TextBlock Grid.Column="1"
                                   Text="{x:Bind Severity}" />
                        <TextBlock Grid.Column="2"
                                   Text="{x:Bind Category}"
                                   FontFamily="Consolas" />
                        <TextBlock Grid.Column="3"
                                   Text="{x:Bind Identity}"
                                   TextTrimming="CharacterEllipsis"
                                   IsTextSelectionEnabled="True" />
                        <TextBlock Grid.Column="4"
                                   Text="{x:Bind Endpoint}"
                                   FontFamily="Consolas"
                                   IsTextSelectionEnabled="True" />
                        <TextBlock Grid.Column="5"
                                   Text="{x:Bind Message}"
                                   TextWrapping="Wrap"
                                   IsTextSelectionEnabled="True" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Window>

<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="UpnpSpy.App.Views.DeviceTreeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="using:System"
    xmlns:vm="using:UpnpSpy.Core.ViewModels"
    xmlns:local="using:UpnpSpy.App.Views">

    <UserControl.Resources>
        <!--
            FR-045: every tree row carries a node-kind glyph (Segoe Fluent Icons) so
            devices, services, and actions are distinguishable at a glance:
              device  →  &#xE968; (NetworkAdapter)
              service →  &#xE950; (Component)
              action  →  &#xE945; (LightningBolt)
            FR-044: chevron affordance is provided by pre-seeded "Loading…" children
            in DeviceNodeViewModel / ServiceNodeViewModel — TreeView renders the
            chevron whenever ItemsSource is non-empty.
        -->
        <DataTemplate x:Key="DeviceTemplate" x:DataType="vm:DeviceNodeViewModel">
            <TreeViewItem ItemsSource="{x:Bind Children, Mode=OneWay}">
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <FontIcon Grid.Column="0"
                              FontFamily="{ThemeResource SymbolThemeFontFamily}"
                              Glyph="&#xE968;"
                              FontSize="14"
                              VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1" Orientation="Vertical">
                        <TextBlock Text="{x:Bind Label, Mode=OneWay}" />
                        <TextBlock Text="{x:Bind DetailLabel, Mode=OneWay}"
                                   FontSize="11"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                    </StackPanel>
                </Grid>
                <TreeViewItem.ContextFlyout>
                    <MenuFlyout>
                        <MenuFlyoutItem Text="Fetch XML"
                                        Command="{x:Bind FetchXmlCommand, Mode=OneWay}">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE8A7;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem Text="Properties..."
                                        Click="OnPropertiesClicked"
                                        Tag="{x:Bind Device}">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE946;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                    </MenuFlyout>
                </TreeViewItem.ContextFlyout>
            </TreeViewItem>
        </DataTemplate>

        <DataTemplate x:Key="ServiceTemplate" x:DataType="vm:ServiceNodeViewModel">
            <TreeViewItem ItemsSource="{x:Bind Children, Mode=OneWay}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}"
                              Glyph="&#xE950;"
                              FontSize="14"
                              VerticalAlignment="Center" />
                    <TextBlock Text="{x:Bind Label, Mode=OneWay}"
                               VerticalAlignment="Center" />
                </StackPanel>
                <TreeViewItem.ContextFlyout>
                    <MenuFlyout>
                        <MenuFlyoutItem Text="Fetch service XML"
                                        Command="{x:Bind FetchScpdCommand}">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE8A7;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem Text="Subscribe"
                                        Click="OnSubscribeClicked"
                                        Tag="{x:Bind Service}">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xEC42;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                    </MenuFlyout>
                </TreeViewItem.ContextFlyout>
            </TreeViewItem>
        </DataTemplate>

        <DataTemplate x:Key="ActionTemplate" x:DataType="vm:ActionNodeViewModel">
            <TreeViewItem DoubleTapped="OnActionDoubleTapped">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}"
                              Glyph="&#xE945;"
                              FontSize="14"
                              VerticalAlignment="Center" />
                    <TextBlock Text="{x:Bind Label}"
                               VerticalAlignment="Center" />
                </StackPanel>
            </TreeViewItem>
        </DataTemplate>

        <DataTemplate x:Key="PlaceholderTemplate" x:DataType="sys:String">
            <TreeViewItem Content="{x:Bind}" />
        </DataTemplate>

        <local:DeviceTreeNodeTemplateSelector
            x:Key="NodeTemplateSelector"
            DeviceTemplate="{StaticResource DeviceTemplate}"
            ServiceTemplate="{StaticResource ServiceTemplate}"
            ActionTemplate="{StaticResource ActionTemplate}"
            PlaceholderTemplate="{StaticResource PlaceholderTemplate}" />
    </UserControl.Resources>

    <Grid>
        <TreeView ItemsSource="{x:Bind ViewModel.Devices, Mode=OneWay}"
                  SelectionMode="Single"
                  ItemTemplateSelector="{StaticResource NodeTemplateSelector}"
                  Expanding="OnTreeViewExpanding" />

        <!--
            Empty state: shown beneath the (otherwise empty) TreeView while no
            devices have been discovered yet. Once a device promotes into
            Devices the count flips non-zero and the overlay collapses.
        -->
        <StackPanel Style="{StaticResource EmptyStatePanelStyle}"
                    IsHitTestVisible="False"
                    Visibility="{x:Bind ViewModel.Devices.Count, Mode=OneWay, Converter={StaticResource ZeroCountToVisibility}}">
            <FontIcon Glyph="&#xE968;" Style="{StaticResource EmptyStateGlyphStyle}" />
            <TextBlock Text="No UPnP devices yet"
                       Style="{StaticResource EmptyStateTitleTextBlockStyle}" />
            <TextBlock Style="{StaticResource EmptyStateBodyTextBlockStyle}"
                       Text="Listening for SSDP advertisements on the selected network adapter. If nothing appears, try View → Rescan (F5), or pick a different adapter from View → Network adapter." />
        </StackPanel>
    </Grid>
</UserControl>

<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="UpnpSpy.App.Views.ShellView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:UpnpSpy.Core.ViewModels">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <MenuBar Grid.Row="0">
            <MenuBarItem Title="View">
                <MenuFlyoutItem x:Name="RescanMenuItem"
                                Text="Rescan"
                                Command="{x:Bind ViewModel.RescanCommand}">
                    <MenuFlyoutItem.Icon>
                        <FontIcon Glyph="&#xE72C;" />
                    </MenuFlyoutItem.Icon>
                    <MenuFlyoutItem.KeyboardAccelerators>
                        <KeyboardAccelerator Key="F5" />
                    </MenuFlyoutItem.KeyboardAccelerators>
                </MenuFlyoutItem>
                <MenuFlyoutSubItem x:Name="NetworkAdapterSubMenu"
                                   Text="Network adapter">
                    <MenuFlyoutSubItem.Icon>
                        <FontIcon Glyph="&#xE839;" />
                    </MenuFlyoutSubItem.Icon>
                </MenuFlyoutSubItem>
                <MenuFlyoutSeparator />
                <MenuFlyoutItem x:Name="DiagnosticsMenuItem"
                                Text="Diagnostics"
                                Click="OnDiagnosticsClicked">
                    <MenuFlyoutItem.Icon>
                        <FontIcon Glyph="&#xE9D9;" />
                    </MenuFlyoutItem.Icon>
                    <MenuFlyoutItem.KeyboardAccelerators>
                        <KeyboardAccelerator Key="L" Modifiers="Control" />
                    </MenuFlyoutItem.KeyboardAccelerators>
                </MenuFlyoutItem>
            </MenuBarItem>
        </MenuBar>

        <!--
            Busy InfoBar: visible whenever any of init/rescan/adapter-switch is
            in progress (FR-001-adjacent UX). Severity stays informational; the
            spinner makes the working state obvious.
        -->
        <InfoBar Grid.Row="1"
                 IsOpen="{x:Bind ViewModel.IsBusy, Mode=OneWay}"
                 IsClosable="False"
                 Severity="Informational"
                 Title="{x:Bind ViewModel.BusyTitle, Mode=OneWay}"
                 Message="{x:Bind ViewModel.BusyMessage, Mode=OneWay}">
            <InfoBar.Content>
                <ProgressRing IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}"
                              Width="20" Height="20"
                              HorizontalAlignment="Left"
                              Margin="0,0,0,12" />
            </InfoBar.Content>
        </InfoBar>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="3*" />
            </Grid.ColumnDefinitions>

            <ContentPresenter x:Name="DeviceTreeHost" Grid.Column="0" />

            <Border Grid.Column="1"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1,0,0,0">
                <ContentPresenter x:Name="SsdpLogHost" />
            </Border>
        </Grid>

        <!-- Status bar — adapter + live counts. -->
        <Border Grid.Row="3"
                Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                Padding="12,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6"
                            VerticalAlignment="Center">
                    <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}"
                              Glyph="&#xE839;"
                              FontSize="12"
                              Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock Text="{x:Bind ViewModel.AdapterDisplay, Mode=OneWay}"
                               Style="{ThemeResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>

                <!-- Spacer column 1 -->

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6"
                            VerticalAlignment="Center" Margin="0,0,16,0">
                    <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}"
                              Glyph="&#xE968;"
                              FontSize="12"
                              Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock Text="{x:Bind ViewModel.DeviceCountText, Mode=OneWay}"
                               Style="{ThemeResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>

                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="6"
                            VerticalAlignment="Center">
                    <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}"
                              Glyph="&#xE7C3;"
                              FontSize="12"
                              Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock Text="{x:Bind ViewModel.SsdpLogCountText, Mode=OneWay}"
                               Style="{ThemeResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>

<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="UpnpSpy.App.Views.ShellView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <MenuBar Grid.Row="0">
            <MenuBarItem Title="View">
                <MenuFlyoutItem Text="Rescan"
                                Command="{x:Bind ViewModel.RescanCommand}" />
                <MenuFlyoutSubItem x:Name="NetworkAdapterSubMenu"
                                   Text="Network adapter" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem x:Name="DiagnosticsMenuItem"
                                Text="Diagnostics"
                                Click="OnDiagnosticsClicked" />
            </MenuBarItem>
        </MenuBar>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="3*" />
            </Grid.ColumnDefinitions>

            <ContentPresenter x:Name="DeviceTreeHost" Grid.Column="0" />

            <Border Grid.Column="1"
                    BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                    BorderThickness="1,0,0,0">
                <ContentPresenter x:Name="SsdpLogHost" />
            </Border>
        </Grid>
    </Grid>
</UserControl>

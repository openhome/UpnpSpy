<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="UpnpSpy.App.Views.InvocationPopup"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:UpnpSpy.Core.ViewModels"
    Title="Invoke action">
    <Grid x:Name="Root" Padding="16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="TitleText"
                   Grid.Row="0"
                   FontSize="18"
                   FontWeight="SemiBold" />

        <InfoBar x:Name="DeviceUnreachableBar"
                 Grid.Row="1"
                 IsOpen="False"
                 IsClosable="False"
                 Severity="Warning"
                 Title="Device no longer reachable"
                 Message="The device has gone away. Close this window." />

        <ItemsControl x:Name="InputsList" Grid.Row="2">
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:InvocationInputViewModel">
                    <Grid ColumnSpacing="8" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{x:Bind Name}"
                                   VerticalAlignment="Center" />
                        <TextBox Grid.Column="1"
                                 PlaceholderText="{x:Bind DataType, Mode=OneWay}"
                                 Text="{x:Bind Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    Spacing="8">
            <Button x:Name="InvokeButton"
                    Content="Invoke"
                    Style="{ThemeResource AccentButtonStyle}" />
            <ProgressRing x:Name="BusyRing"
                          IsActive="False"
                          Width="20"
                          Height="20" />
        </StackPanel>

        <ScrollViewer Grid.Row="4" VerticalScrollMode="Auto">
            <StackPanel x:Name="ResultPanel" Spacing="12" Visibility="Collapsed">
                <Border x:Name="SuccessPanel"
                        Visibility="Collapsed"
                        Background="{ThemeResource SystemFillColorSuccessBackgroundBrush}"
                        Padding="12"
                        CornerRadius="4">
                    <StackPanel Spacing="8">
                        <TextBlock x:Name="SuccessMessageText"
                                   FontWeight="SemiBold" />
                        <ItemsControl x:Name="OutputsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:InvocationOutputViewModel">
                                    <Grid ColumnSpacing="8" Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="180" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{x:Bind Name}"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{x:Bind Value}"
                                                   TextWrapping="Wrap"
                                                   IsTextSelectionEnabled="True" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border x:Name="FaultPanel"
                        Visibility="Collapsed"
                        Background="{ThemeResource SystemFillColorCautionBackgroundBrush}"
                        Padding="12"
                        CornerRadius="4">
                    <StackPanel Spacing="6">
                        <TextBlock x:Name="FaultHeader"
                                   FontWeight="SemiBold"
                                   Text="UPnP fault" />
                        <TextBlock x:Name="FaultStatusText" />
                        <TextBlock x:Name="FaultCodeText" />
                        <TextBlock x:Name="FaultDescriptionText" TextWrapping="Wrap" />
                        <Expander Header="Raw fault XML">
                            <TextBox x:Name="FaultRawXmlText"
                                     AcceptsReturn="True"
                                     IsReadOnly="True"
                                     FontFamily="Consolas"
                                     TextWrapping="Wrap" />
                        </Expander>
                    </StackPanel>
                </Border>

                <Border x:Name="TransportPanel"
                        Visibility="Collapsed"
                        Background="{ThemeResource SystemFillColorCriticalBackgroundBrush}"
                        Padding="12"
                        CornerRadius="4">
                    <StackPanel Spacing="6">
                        <TextBlock FontWeight="SemiBold" Text="Transport error" />
                        <TextBlock x:Name="TransportMessageText" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>

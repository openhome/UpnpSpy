root = true

[*]
charset = utf-8
end_of_line = crlf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

[*.{xml,xaml,csproj,props,targets,appxmanifest,nuspec,config,resx,json,yml,yaml}]
indent_size = 2

[*.{md,markdown}]
trim_trailing_whitespace = false

[*.cs]
# Sort System.* first, no separation
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = false

# var
csharp_style_var_for_built_in_types = true:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = false:suggestion

# File-scoped namespaces
csharp_style_namespace_declarations = file_scoped:warning

# Prefer this. qualification off (consistent with implicit usings style)
dotnet_style_qualification_for_field = false:suggestion
dotnet_style_qualification_for_property = false:suggestion
dotnet_style_qualification_for_method = false:suggestion
dotnet_style_qualification_for_event = false:suggestion

# Expression-bodied members
csharp_style_expression_bodied_methods = when_on_single_line:suggestion
csharp_style_expression_bodied_properties = when_on_single_line:suggestion

# Modern features
# Braces required only for multi-line blocks; the codebase's house style
# allows compact one-liners (`if (x) return;`, `lock (g) ...`).
csharp_prefer_braces = when_multiline:warning
csharp_style_pattern_matching_over_is_with_cast_check = true:warning
csharp_style_pattern_matching_over_as_with_null_check = true:warning

# File header (template empty -> rule has nothing to enforce; severity still 'error' per plan)
file_header_template = unset
dotnet_diagnostic.IDE0073.severity = error

# Treat unused usings as errors so they're cleaned up on build
dotnet_diagnostic.IDE0005.severity = warning

# Allow underscore-prefixed private fields
dotnet_naming_rule.private_fields_with_underscore.symbols = private_fields
dotnet_naming_rule.private_fields_with_underscore.style = underscore_prefix
dotnet_naming_rule.private_fields_with_underscore.severity = suggestion
dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private
dotnet_naming_style.underscore_prefix.required_prefix = _
dotnet_naming_style.underscore_prefix.capitalization = camel_case
